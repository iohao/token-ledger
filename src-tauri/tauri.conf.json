{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenLedger",
  "version": "0.4.2",
  "identifier": "me.ionet.tokenledger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:25174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TokenLedger",
        "width": 1380,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 780,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFRjgwNkZBRTQwODE1REMKUldUY0ZRamsrZ2I0bmtZbGpaTWloYkhabXFsNG9ORjNlVk56M1lsQ2d5OTVqMCszZjhDQkMwa0UK",
      "endpoints": [
        "https://cdn.jsdelivr.net/gh/iohao/token-ledger@release-manifest/latest.json",
        "https://github.com/iohao/token-ledger/releases/latest/download/latest.json",
        "https://gh-proxy.com/https://github.com/iohao/token-ledger/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
